#!/bin/sh

DAEMON=/usr/bin/lvgl9-demo
PIDFILE=/var/run/lvgl9-demo.pid
LOGFILE=/var/log/lvgl9-demo.log
FBDEV=${LVGL_FBDEV:-/dev/fb0}
EVDEV=${LVGL_EVDEV:-/dev/input/event0}

start() {
    [ -x "$DAEMON" ] || return 0

    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE" 2>/dev/null)" 2>/dev/null; then
        return 0
    fi

    mkdir -p /var/run /var/log

    i=0
    while [ "$i" -lt 10 ]; do
        [ -e "$FBDEV" ] && break
        i=$((i + 1))
        sleep 1
    done

    "$DAEMON" "$FBDEV" "$EVDEV" >>"$LOGFILE" 2>&1 &
    echo "$!" >"$PIDFILE"
}

stop() {
    if [ -f "$PIDFILE" ]; then
        pid="$(cat "$PIDFILE" 2>/dev/null)"
        if [ -n "$pid" ]; then
            kill "$pid" 2>/dev/null || true
        fi
        rm -f "$PIDFILE"
    fi
}

case "$1" in
    start)
        start
        ;;
    stop)
        stop
        ;;
    restart)
        stop
        start
        ;;
    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
        ;;
esac

exit 0
